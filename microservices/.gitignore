# Inherits from root .gitignore — add microservices-specific overrides below.

# ============================================================
# Gradle
# ============================================================
.gradle/
build/
*/build/
**/build/
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ============================================================
# Java / Kotlin compiled output
# ============================================================
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar
*.war
*.ear
*.nar

# Kotlin compiler artifacts
.kotlin/

# ============================================================
# Spring Boot
# ============================================================
spring-shell.log
HELP.md

# ============================================================
# Node.js / React / Vite (if a frontend module is added)
# ============================================================
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/

# ============================================================
# IntelliJ IDEA / JetBrains
# ============================================================
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ============================================================
# Eclipse / STS
# ============================================================
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# ============================================================
# NetBeans
# ============================================================
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# ============================================================
# VS Code
# ============================================================
.vscode/

# ============================================================
# macOS
# ============================================================
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*
__MACOSX/

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# Secrets & certificates (NEVER commit these)
# ============================================================
*.p8
*.p12
*.pem
*.key
*.jks
*.keystore
*.truststore

# ============================================================
# Environment & local config
# ============================================================
.env
.env.local
.env.*.local
local.properties
application-local.yml
application-local.properties

# ============================================================
# Docker
# ============================================================
Dockerfile.local
docker-compose.override.yml

# ============================================================
# Cache & temp files
# ============================================================
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

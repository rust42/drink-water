# Source and test files — the JAR is pre-built by Gradle before Docker runs
src/
build/classes/
build/tmp/
build/reports/
build/generated/

# Gradle internals
.gradle/
gradle/

# IDE and editor
.idea/
*.iml
*.iws
*.ipr
.vscode/

# Git
.git/
.gitignore

# Docs and CI
*.md
.github/

# Misc
*.log

# APNS certs are injected via Kubernetes secrets at runtime — never bake them in
certs/
*.p8
*.p12
*.pem
